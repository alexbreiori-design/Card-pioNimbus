# Copie para .env.local:  cp env.staging.example .env.local
# Use credenciais do Supabase STAGING — nunca produção no dia a dia.

NEXT_PUBLIC_NIMBUS_APP_ENV=local
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO-STAGING.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

NEXT_PUBLIC_SITE_URL=http://localhost:3010
NEXT_PUBLIC_ROOT_DOMAIN=
NEXT_PUBLIC_DEFAULT_STORE_SLUG=loja-demo

NIMBUS_SUPER_ADMIN_EMAILS=seu-email@gmail.com

# Pagamentos online (criptografia das API keys / tokens no banco)
PAYMENTS_ENC_KEY=

# Mercado Pago (OAuth + webhooks)
MERCADO_PAGO_CLIENT_ID=
MERCADO_PAGO_CLIENT_SECRET=
MERCADO_PAGO_WEBHOOK_SECRET=

# Asaas — token do webhook (header asaas-access-token)
# Configure a mesma string no painel Asaas → Integrações → Webhook
# URL: https://SEU-DOMINIO/api/pagamentos/webhook/asaas
ASAAS_WEBHOOK_TOKEN=
